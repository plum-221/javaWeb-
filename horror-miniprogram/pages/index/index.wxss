.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a0a 0%, #1a0505 50%, #0a0a0a 100%);
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

.title-section {
  text-align: center;
  margin-bottom: 60rpx;
  animation: flicker 3s infinite;
}

.title {
  font-size: 64rpx;
  color: #8b0000;
  font-weight: bold;
  display: block;
  text-shadow: 0 0 20rpx #ff0000, 0 0 40rpx #8b0000;
  letter-spacing: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-top: 20rpx;
  letter-spacing: 2rpx;
}

.warning-box {
  background: rgba(139, 0, 0, 0.2);
  border: 2rpx solid #8b0000;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  animation: pulse 2s infinite;
}

.warning-text {
  color: #ff6b6b;
  font-size: 28rpx;
  display: block;
  text-align: center;
  margin-bottom: 10rpx;
}

.warning-sub {
  color: #999;
  font-size: 24rpx;
  display: block;
  text-align: center;
}

.menu-section {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.menu-item {
  background: linear-gradient(135deg, rgba(30, 30, 30, 0.9) 0%, rgba(20, 20, 20, 0.9) 100%);
  border: 1rpx solid #333;
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.menu-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(139, 0, 0, 0.1), transparent);
  transition: left 0.5s ease;
}

.menu-item:active::before {
  left: 100%;
}

.menu-icon {
  font-size: 60rpx;
  flex-shrink: 0;
}

.menu-title {
  font-size: 34rpx;
  color: #e0e0e0;
  font-weight: bold;
  flex: 1;
}

.menu-desc {
  font-size: 24rpx;
  color: #666;
  flex: 1;
  text-align: right;
}

.footer {
  position: fixed;
  bottom: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.footer-text {
  color: #444;
  font-size: 24rpx;
  display: block;
  margin-bottom: 10rpx;
}

.footer-hint {
  color: #333;
  font-size: 22rpx;
  display: block;
}

.scare-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000;
  z-index: 9999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.1s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scare-overlay.active {
  opacity: 1;
  visibility: visible;
}

.scare-image {
  width: 100%;
  height: 100%;
}

@keyframes flicker {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.8; }
  52% { opacity: 1; }
  54% { opacity: 0.7; }
  56% { opacity: 1; }
}

@keyframes pulse {
  0%, 100% { 
    box-shadow: 0 0 10rpx rgba(139, 0, 0, 0.3);
    transform: scale(1);
  }
  50% { 
    box-shadow: 0 0 30rpx rgba(139, 0, 0, 0.6);
    transform: scale(1.02);
  }
}
