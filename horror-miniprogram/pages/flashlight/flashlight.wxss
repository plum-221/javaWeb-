.flashlight-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000;
  overflow: hidden;
}

.darkness-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(
    circle 150px at var(--light-x, 50%) var(--light-y, 50%),
    transparent 0%,
    rgba(0, 0, 0, 0.95) 40%,
    rgba(0, 0, 0, 1) 100%
  );
  z-index: 1;
}

.flashlight-beam {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 2;
  pointer-events: none;
}

.beam-center {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(255, 255, 200, 0.8) 0%,
    rgba(255, 255, 150, 0.4) 50%,
    transparent 70%
  );
  box-shadow: 
    0 0 60px rgba(255, 255, 200, 0.6),
    0 0 100px rgba(255, 255, 150, 0.3);
}

.beam-outer {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 300px;
  height: 300px;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(255, 255, 200, 0.15) 0%,
    transparent 60%
  );
}

.hidden-item {
  position: absolute;
  opacity: 0;
  transition: opacity 0.5s ease;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  pointer-events: none;
}

.hidden-item.revealed {
  opacity: 1;
  animation: itemPulse 2s infinite;
}

@keyframes itemPulse {
  0%, 100% { 
    transform: scale(1);
    filter: brightness(1);
  }
  50% { 
    transform: scale(1.1);
    filter: brightness(1.3);
  }
}

.item-icon {
  font-size: 80rpx;
  text-shadow: 0 0 20rpx rgba(255, 255, 200, 0.8);
}

.item-text {
  font-size: 24rpx;
  color: #ffcc00;
  margin-top: 10rpx;
  text-align: center;
  text-shadow: 0 0 10rpx rgba(255, 204, 0, 0.8);
}

.scare-element {
  position: absolute;
  opacity: 0;
  visibility: hidden;
  transition: all 0.1s ease;
  z-index: 10;
}

.scare-element.visible {
  opacity: 1;
  visibility: visible;
  animation: scareFlash 0.3s infinite;
}

@keyframes scareFlash {
  0%, 100% { 
    transform: scale(1) rotate(0deg);
    filter: hue-rotate(0deg);
  }
  50% { 
    transform: scale(1.2) rotate(5deg);
    filter: hue-rotate(180deg);
  }
}

.scare-icon {
  font-size: 150rpx;
  text-shadow: 0 0 40rpx #ff0000;
}

.hint-box {
  position: fixed;
  bottom: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(20, 20, 20, 0.9);
  border: 1rpx solid #444;
  border-radius: 16rpx;
  padding: 20rpx 40rpx;
  z-index: 20;
}

.hint-text {
  font-size: 26rpx;
  color: #999;
}

.battery-indicator {
  position: fixed;
  top: 30rpx;
  right: 40rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  z-index: 20;
  background: rgba(20, 20, 20, 0.8);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  border: 1rpx solid #333;
}

.battery-level {
  height: 20rpx;
  background: linear-gradient(90deg, #8b0000, #ff0000);
  border-radius: 4rpx;
  transition: width 1s ease;
}

.battery-text {
  font-size: 22rpx;
  color: #ff6b6b;
  min-width: 60rpx;
}

.start-hint {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(30, 30, 30, 0.95);
  border: 2rpx solid #8b0000;
  border-radius: 24rpx;
  padding: 60rpx 80rpx;
  text-align: center;
  z-index: 100;
  transition: all 0.3s ease;
}

.start-hint.hidden {
  opacity: 0;
  visibility: hidden;
  transform: translate(-50%, -50%) scale(0.8);
}

.start-title {
  font-size: 48rpx;
  color: #8b0000;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
  text-shadow: 0 0 20rpx rgba(139, 0, 0, 0.8);
}

.start-desc {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 30rpx;
}

.start-warning {
  font-size: 24rpx;
  color: #ff6b6b;
  display: block;
}
